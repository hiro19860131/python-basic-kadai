      "source": [
        "def calculate_total(price):\n",
        "    total = int(price * 1.1)\n",
        "    tax = int(price * 0.1)\n",
        "    return total, tax\n",
        "\n",
        "total, tax = calculate_total(100)\n",
        "\n",
        "print(\"合計額:\", total, \"円\")\n",
        "print(\"消費税額:\", tax, \"円\")\n",
        "\n"
      ],
