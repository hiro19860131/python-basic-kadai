        "def calculate_total (price):\n",
        "    total = (price)\n",
        "    total_tax= (price * 0.1)\n",
        "\n",
        "    return (total + total_tax)\n",
        "\n",
        "calculate_total(100)\n",
        "\n",
        "\n"
